@model Ogloszenie
@{
    ViewData["Title"] = "Edytuj ogłoszenie";
}

<h1 class="h2 mb-4">Edytuj ogłoszenie</h1>

<div class="row">
    <div class="col-lg-8">
        <form asp-action="Edit" method="post" class="card shadow-sm">
            <div class="card-body">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="DataUtworzenia" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Tytul" class="form-label"></label>
                    <input asp-for="Tytul" class="form-control" />
                    <span asp-validation-for="Tytul" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Opis" class="form-label"></label>
                    <textarea asp-for="Opis" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Opis" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Cena" class="form-label"></label>
                        <input asp-for="Cena" class="form-control" type="number" step="0.01" min="0" />
                        <span asp-validation-for="Cena" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Kategoria" class="form-label"></label>
                        <select asp-for="Kategoria" class="form-select" asp-items="Html.GetEnumSelectList<Kategoria>()"></select>
                        <span asp-validation-for="Kategoria" class="text-danger"></span>
                    </div>
                </div>

                <p class="text-muted small">Data dodania: @Model.DataUtworzenia.ToString("dd.MM.yyyy HH:mm")</p>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Zapisz zmiany</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
