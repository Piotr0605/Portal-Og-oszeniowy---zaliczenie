<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portal Ogłoszeń</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Ogloszenia" asp-action="Index">Portal Ogłoszeń</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nawigacja">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="nawigacja">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Ogloszenia" asp-action="Index">Lista ogłoszeń</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-light text-primary ms-lg-2 px-3" asp-controller="Ogloszenia" asp-action="Create">+ Dodaj ogłoszenie</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container pb-5">
        @if (TempData["Komunikat"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Komunikat"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted py-3 mt-auto">
        <div class="container text-center">
            Portal Ogłoszeń &mdash; projekt zaliczeniowy, ASP.NET Core MVC
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
